@using Lidstroem.Frontend.Core.Models
@using Lidstroem.Frontend.Core.Services

@* FieldEditor routes each FieldType to its appropriate input component *@

@switch (Field.Type)
{
    case FieldType.Text:
        @if (Field.UiHint == "multiline" || Field.MaxLength > 500)
        {
            <textarea class="field-input field-textarea"
                      value="@StringValue"
                      @oninput="e => Emit(e.Value)"
                      maxlength="@Field.MaxLength"
                      disabled="@Disabled"
                      placeholder="@Field.DisplayName"></textarea>
        }
        else
        {
            <input type="@(Field.UiHint ?? "text")"
                   class="field-input"
                   value="@StringValue"
                   @oninput="e => Emit(e.Value)"
                   maxlength="@Field.MaxLength"
                   disabled="@Disabled"
                   placeholder="@Field.DisplayName" />
        }
        break;

    case FieldType.Number:
        <input type="number"
               class="field-input"
               value="@StringValue"
               @oninput="e => Emit(e.Value)"
               min="@Field.Min"
               max="@Field.Max"
               disabled="@Disabled" />
        break;

    case FieldType.Decimal:
        <input type="number"
               class="field-input"
               value="@StringValue"
               @oninput="e => Emit(e.Value)"
               step="0.01"
               min="@Field.Min"
               max="@Field.Max"
               disabled="@Disabled" />
        break;

    case FieldType.Boolean:
        <label class="toggle-label">
            <input type="checkbox"
                   class="toggle-input"
                   checked="@BoolValue"
                   @onchange="e => Emit(e.Value)"
                   disabled="@Disabled" />
            <span class="toggle-track"></span>
        </label>
        break;

    case FieldType.Date:
        <input type="date"
               class="field-input"
               value="@DateValue"
               @oninput="e => Emit(e.Value)"
               disabled="@Disabled" />
        break;

    case FieldType.DateTime:
        <input type="datetime-local"
               class="field-input"
               value="@DateTimeValue"
               @oninput="e => Emit(e.Value)"
               disabled="@Disabled" />
        break;

    case FieldType.Enum:
        <select class="field-input field-select"
                value="@StringValue"
                @onchange="e => Emit(e.Value)"
                disabled="@Disabled">
            <option value="">— Select —</option>
            @foreach (var opt in Field.EnumOptions ?? Array.Empty<EnumOption>())
            {
                <option value="@opt.Value" selected="@(StringValue == opt.Value)">
                    @opt.DisplayName
                </option>
            }
        </select>
        break;

    case FieldType.Relation:
        <RelationPicker Field="@Field"
                        Value="@StringValue"
                        ValueChanged="v => Emit(v)"
                        Disabled="@Disabled" />
        break;

    case FieldType.MultiRelation:
        <MultiRelationPicker Field="@Field"
                             Value="@StringValue"
                             ValueChanged="v => Emit(v)"
                             Disabled="@Disabled" />
        break;

    case FieldType.RichText:
        <textarea class="field-input field-richtext"
                  value="@StringValue"
                  @oninput="e => Emit(e.Value)"
                  disabled="@Disabled"
                  rows="8"></textarea>
        break;

    case FieldType.File:
        <div class="field-file">
            @if (!string.IsNullOrEmpty(StringValue))
            {
                <div class="file-current">
                    <Icon Name="paperclip" Size="14" />
                    <span>@StringValue</span>
                </div>
            }
            <input type="file"
                   class="field-input-file"
                   disabled="@Disabled"
                   @onchange="HandleFileChange" />
        </div>
        break;

    default:
        <input type="text"
               class="field-input"
               value="@StringValue"
               @oninput="e => Emit(e.Value)"
               disabled="@Disabled" />
        break;
}

@code {
    [Parameter, EditorRequired] public FieldDefinition Field { get; set; } = null!;
    [Parameter] public object? Value { get; set; }
    [Parameter] public EventCallback<object?> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private string StringValue   => Value?.ToString() ?? string.Empty;
    private bool   BoolValue     => Value is bool b ? b : bool.TryParse(Value?.ToString(), out var r) && r;
    private string DateValue     => Value is DateTime dt ? dt.ToString("yyyy-MM-dd") : StringValue;
    private string DateTimeValue => Value is DateTime dt2 ? dt2.ToString("yyyy-MM-ddTHH:mm") : StringValue;

    private async Task Emit(object? value) => await ValueChanged.InvokeAsync(value);

    private async Task HandleFileChange(ChangeEventArgs e)
    {
        // File uploads are handled by the Resources plugin endpoint
        // For now, emit the filename as a placeholder
        await Emit(e.Value?.ToString());
    }
}
