@using System.Text.Json
@using Lidstroem.Frontend.Core.Models
@using Lidstroem.Frontend.Core.Services
@inject ApiClient Api
@inject SchemaService Schema
@inject IJSRuntime JS

<div class="relation-picker" id="@_pickerId">
    <input type="text"
           class="field-input"
           value="@_displayValue"
           @oninput="OnSearchInput"
           @onfocus="OpenDropdown"
           placeholder="@("Search " + Field.DisplayName + "…")"
           disabled="@Disabled"
           autocomplete="off" />

    @if (_open)
    {
        @if (_options.Count > 0)
        {
            <ul class="relation-dropdown">
                @foreach (var opt in _options)
                {
                    var optId    = opt.Id;
                    var optLabel = opt.Label;
                    <li class="relation-option"
                        @onclick="() => Select(optId, optLabel)"
                        @onclick:stopPropagation>
                        @optLabel
                    </li>
                }
            </ul>
        }
        else if (!string.IsNullOrEmpty(_search))
        {
            <ul class="relation-dropdown">
                <li class="relation-empty">No results</li>
            </ul>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public FieldDefinition Field       { get; set; } = null!;
    [Parameter]                 public string?         Value       { get; set; }
    [Parameter]                 public EventCallback<string?> ValueChanged { get; set; }
    [Parameter]                 public bool            Disabled    { get; set; }

    private string  _search       = string.Empty;
    private string  _displayValue = string.Empty;
    private bool    _open;
    private string  _pickerId     = "rp-" + Guid.NewGuid().ToString("N")[..8];
    private List<(int Id, string Label)> _options = new();
    private DotNetObjectReference<RelationPicker>? _selfRef;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Value) && string.IsNullOrEmpty(_displayValue))
            await LoadSelectedLabel(Value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            // Register a document click listener that calls Close() when the
            // user clicks outside this component. Fixes: dropdown stayed open
            // indefinitely after selecting or clicking elsewhere.
            await JS.InvokeVoidAsync("lidstroem.registerClickOutside", _pickerId, _selfRef);
        }
    }

    [JSInvokable]
    public void Close()
    {
        _open = false;
        InvokeAsync(StateHasChanged);
    }

    private bool _disposed;

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        _selfRef?.Dispose();
        // BUG-38 FIX: Fire-and-forget JS.InvokeVoidAsync after disposal could run
        // after the JS runtime is torn down, causing ObjectDisposedException.
        // Use a synchronous best-effort pattern: only invoke if not already disposed.
        try
        {
            _ = JS.InvokeVoidAsync("lidstroem.unregisterClickOutside", _pickerId);
        }
        catch { /* JS runtime may already be disposed — swallow silently */ }
    }

    private async Task LoadSelectedLabel(string rawId)
    {
        if (!int.TryParse(rawId, out var id) || string.IsNullOrEmpty(Field.RelatedEntityType)) return;
        var relSchema = await Schema.GetAsync(Field.RelatedEntityType);
        if (relSchema == null) return;
        var item = await Api.GetOneAsync(relSchema.ApiBasePath + "/" + id);
        if (item.HasValue) _displayValue = GetLabel(item.Value, relSchema);
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _displayValue = _search;
        _open = true;
        await LoadOptions();
    }

    private async Task LoadOptions()
    {
        if (string.IsNullOrEmpty(Field.RelatedEntityType)) return;
        var relSchema = await Schema.GetAsync(Field.RelatedEntityType);
        if (relSchema == null) return;

        var items = await Api.GetListAsync(relSchema.ApiBasePath + "?page=1&pageSize=20");
        _options = items?
            .Select(el => (Id: GetId(el), Label: GetLabel(el, relSchema)))
            .Where(o => o.Id > 0 && (string.IsNullOrEmpty(_search) ||
                o.Label.Contains(_search, StringComparison.OrdinalIgnoreCase)))
            .ToList() ?? new();
    }

    private void OpenDropdown()
    {
        _open = true;
        _ = LoadOptions();
    }

    private async Task Select(int id, string label)
    {
        _displayValue = label;
        _search       = string.Empty;
        _open         = false;
        await ValueChanged.InvokeAsync(id.ToString());
    }

    private static int    GetId(JsonElement el) =>
        el.TryGetProperty("id", out var p) ? p.GetInt32() : 0;

    private static string GetLabel(JsonElement el, EntitySchema schema)
    {
        foreach (var col in schema.DefaultListColumns)
            if (el.TryGetProperty(col, out var v) && v.ValueKind == JsonValueKind.String)
                return v.GetString() ?? col;
        foreach (var key in new[] { "name", "title", "displayName" })
            if (el.TryGetProperty(key, out var v) && v.ValueKind == JsonValueKind.String)
                return v.GetString() ?? key;
        return el.TryGetProperty("id", out var id) ? "#" + id.GetInt32() : "?";
    }
}
