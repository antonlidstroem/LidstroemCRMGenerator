@using Lidstroem.Frontend.Core.Services
@using Lidstroem.Frontend.Core.Models
@using Lidstroem.Frontend.Layout
@implements IDisposable
@inject AuthService Auth
@inject SchemaService Schema
@inject PermissionService Permissions
@inject SkinService Skin
@inject AppState State
@inject CustomPageRegistry CustomPages
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IConfiguration Config

@if (State.IsLoading)
{
    <div class="boot-screen">
        <div class="boot-spinner"></div>
    </div>
}
else
{
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@GetLayout()" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@GetLayout()">
                <div class="not-found">
                    <h1>404</h1>
                    <p>This page does not exist.</p>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
}

@code {
    private string? _tenantSlug;

    protected override async Task OnInitializedAsync()
    {
        State.SetLoading(true);

        try
        {
            _tenantSlug = await ResolveSlugAsync();
            State.SetTenantSlug(_tenantSlug);

            // Boot order matters:
            // 1. Skin — applied before first render to prevent FOUC
            // 2. Auth — restores JWT from storage
            // 3. Permissions — only if authenticated
            // 4. Custom pages — loaded for all visitors (routes affect layout)
            await BootstrapSkinAsync(_tenantSlug);
            await Auth.InitializeAsync();

            if (Auth.IsAuthenticated)
                await Permissions.LoadAsync();

            await CustomPages.LoadAsync(GetApiClient(), _tenantSlug);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[App] Boot error: {ex.Message}");
        }
        finally
        {
            State.SetBootstrapped();
        }

        // FIX: Subscribe to auth state changes after boot so that login/logout
        // triggers a re-render and GetLayout() picks the correct layout immediately.
        // Without this the layout stays as AuthLayout after login until the user
        // manually navigates.
        Auth.AuthStateChanged += OnAuthStateChanged;

        // FIX: Auth guard — redirect any unauthenticated visitor away from
        // protected routes. /login and /pub/* are always accessible.
        GuardRoute();
        Nav.LocationChanged += OnLocationChanged;
    }

    // Called on every navigation event to enforce the auth guard.
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => GuardRoute();

    private void GuardRoute()
    {
        if (Auth.IsAuthenticated) return;

        var path = new Uri(Nav.Uri).AbsolutePath;
        var isPublic = path.StartsWith("/login", StringComparison.OrdinalIgnoreCase)
                    || path.StartsWith("/pub/",  StringComparison.OrdinalIgnoreCase);

        if (!isPublic)
            Nav.NavigateTo("/login", replace: true);
    }

    private async void OnAuthStateChanged()
    {
        // Reload permissions whenever auth state changes (login / logout).
        if (Auth.IsAuthenticated)
            await Permissions.LoadAsync();
        else
            Permissions.Clear();

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Auth.AuthStateChanged -= OnAuthStateChanged;
        Nav.LocationChanged   -= OnLocationChanged;
    }

    [Inject] private ApiClient ApiClient { get; set; } = null!;
    private ApiClient GetApiClient() => ApiClient;

    private async Task<string> ResolveSlugAsync()
    {
        try
        {
            var uri  = new Uri(Nav.Uri);
            var host = uri.Host;

            var slug = ExtractSubdomain(host);
            if (!string.IsNullOrEmpty(slug)) return slug;

            var byHostSlug = await TryResolveByHostAsync(host);
            if (!string.IsNullOrEmpty(byHostSlug)) return byHostSlug;
        }
        catch { }

        return Config["TenantSlug"] ?? Config["FallbackTenantSlug"] ?? "default";
    }

    private static string? ExtractSubdomain(string host)
    {
        var hostname = host.Split(':')[0];
        var parts = hostname.Split('.');
        if (parts.Length < 3) return null;
        if (parts.All(p => int.TryParse(p, out _))) return null;
        if (parts.Length == 3)
        {
            var candidate = parts[0].ToLowerInvariant();
            var ignored = new HashSet<string> { "www", "app", "api", "mail", "smtp" };
            if (ignored.Contains(candidate)) return null;
            return candidate;
        }
        return null;
    }

    private async Task<string?> TryResolveByHostAsync(string host)
    {
        try
        {
            var apiBase = Config["ApiBaseUrl"] ?? Nav.BaseUri;
            if (string.IsNullOrWhiteSpace(apiBase)) return null;
            using var http = new HttpClient { BaseAddress = new Uri(apiBase) };
            http.Timeout = TimeSpan.FromSeconds(3);
            var response = await http.GetAsync($"/pub/site/by-host/{Uri.EscapeDataString(host)}");
            if (!response.IsSuccessStatusCode) return null;
            var dto = await response.Content.ReadFromJsonAsync<SlugDto>();
            return dto?.Slug;
        }
        catch { return null; }
    }

    private async Task BootstrapSkinAsync(string slug)
    {
        try
        {
            var apiBase = Config["ApiBaseUrl"] ?? Nav.BaseUri;
            if (!string.IsNullOrWhiteSpace(apiBase))
            {
                using var http = new HttpClient { BaseAddress = new Uri(apiBase) };
                http.Timeout = TimeSpan.FromSeconds(3);
                var config = await http.GetFromJsonAsync<SiteConfig>($"/pub/site/{slug}");

                if (config != null)
                {
                    State.SetSiteConfig(config);
                    var prefersDark = config.DarkMode == "dark" ||
                        (config.DarkMode == "system" &&
                         await JS.InvokeAsync<bool>("matchMedia", "(prefers-color-scheme: dark)"));
                    await Skin.ApplyAsync(config, prefersDark);
                    await JS.InvokeVoidAsync("lidstroem.setSiteMetadata", config.SiteName, config.FaviconUrl);
                    return;
                }
            }
        }
        catch { }

        await Skin.ApplyAsync(
            new SiteConfig("Lidstroem", null, null, "Clarity", "Slate", null, "system"),
            false);
    }

    private Type GetLayout() => Auth.IsAuthenticated
        ? State.SiteConfig?.ThemeName switch
        {
            "Momentum" => typeof(MomentumLayout),
            "Focus"    => typeof(FocusLayout),
            _          => typeof(ClarityLayout)
        }
        : typeof(AuthLayout);

    private record SlugDto(string Slug);
}
