@page "/login"
@using Lidstroem.Frontend.Core.Auth
@using Lidstroem.Frontend.Core.Services
@inject AuthService Auth
@inject NavigationManager Nav
@inject PermissionService Permissions

<PageTitle>Sign in</PageTitle>

<div class="login-card">
    <div class="login-card-header">
        <h1 class="login-title">Sign in</h1>
        <p class="login-subtitle">Enter your credentials to continue</p>
    </div>

    <div class="login-form">
        <div class="form-field">
            <label class="field-label">Email or username</label>
            <input type="text"
                   class="field-input @(_error != null ? "field-input--error" : "")"
                   @bind="_identifier"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   placeholder="you@example.com"
                   autocomplete="username" />
        </div>

        <div class="form-field">
            <label class="field-label">Password</label>
            <input type="password"
                   class="field-input @(_error != null ? "field-input--error" : "")"
                   @bind="_password"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   placeholder="••••••••"
                   autocomplete="current-password" />
        </div>

        @if (_error != null)
        {
            <div class="form-error">
                <Icon Name="alert-circle" Size="14" />
                @_error
            </div>
        }

        <button class="btn btn-primary btn-full @(_loading ? "btn-busy" : "")"
                @onclick="LoginAsync"
                disabled="@(_loading || string.IsNullOrWhiteSpace(_identifier) || string.IsNullOrWhiteSpace(_password))">
            @if (_loading)
            {
                <span class="btn-spinner"></span>
            }
            Sign in
        </button>
    </div>
</div>

@code {
    private string _identifier = string.Empty;
    private string _password = string.Empty;
    private string? _error;
    private bool _loading;

    protected override void OnInitialized()
    {
        if (Auth.IsAuthenticated)
            Nav.NavigateTo("/dashboard");
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoginAsync();
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_identifier) || string.IsNullOrWhiteSpace(_password))
            return;

        _loading = true;
        _error   = null;

        try
        {
            var success = await Auth.LoginAsync(_identifier, _password);
            if (success)
            {
                await Permissions.LoadAsync();
                // NavigateTo triggers a component disposal — _loading = false after this
                // is unreachable in the success path, which is fine.
                Nav.NavigateTo("/dashboard");
                return;
            }
            _error = "Invalid credentials. Please try again.";
        }
        catch
        {
            _error = "A network error occurred. Please try again.";
        }
        finally
        {
            // Fix 10: Always reset _loading so the button is not permanently stuck
            // in the busy state if an exception is thrown or auth fails.
            _loading = false;
        }
    }
}
