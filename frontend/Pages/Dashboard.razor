@page "/"
@page "/dashboard"
@using System.Text.Json
@using Lidstroem.Frontend.Core.Models
@using Lidstroem.Frontend.Core.Services
@inject SchemaService Schema
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<div class="dashboard-page">
    <div class="page-header">
        <h1 class="page-title">Dashboard</h1>
    </div>

    <div class="dashboard-grid">
        @foreach (var card in _cards)
        {
            <a href="/entity/@card.EntityType" class="dashboard-card">
                <div class="dashboard-card-icon">
                    <Icon Name="@(card.Icon ?? "layers")" Size="24" />
                </div>
                <div class="dashboard-card-content">
                    <span class="dashboard-card-count">
                        @(card.Count == null ? "—" : card.CountIsApproximate ? $"{card.Count}+" : card.Count.ToString()!)
                    </span>
                    <span class="dashboard-card-label">@card.DisplayNamePlural</span>
                </div>
            </a>
        }
    </div>
</div>

@code {
    private List<DashboardCard> _cards = new();

    protected override async Task OnInitializedAsync()
    {
        var schemas = await Schema.GetAllAsync();
        _cards = schemas.Values
            .OrderBy(s => s.NavOrder)
            // BUG FIX #5: Was constructing the path as "/api/{EntityType.ToLower()}s" which
            // produces wrong URLs for irregular plurals (e.g. "activitys", "fieldreports"
            // becomes "fieldreportss"). Use ApiBasePath from the schema directly.
            .Select(s => new DashboardCard(s.EntityType, s.DisplayNamePlural, s.Icon, s.ApiBasePath, null, false))
            .ToList();

        // Fix 3: Load counts in parallel. We request pageSize=200 (the backend cap).
        // If exactly 200 are returned the tenant may have more — shown as "200+".
        // A dedicated /api/{entity}/count endpoint would be cleaner but requires
        // backend changes; this is an acceptable client-side approximation.
        var tasks = _cards.Select(async (card, i) =>
        {
            var items = await Api.GetListAsync($"{card.ApiPath}?page=1&pageSize=200");
            var count = items?.Count;
            _cards[i] = card with { Count = count, CountIsApproximate = count == 200 };
            StateHasChanged();
        });

        await Task.WhenAll(tasks);
    }

    private record DashboardCard(
        string EntityType,
        string DisplayNamePlural,
        string? Icon,
        string ApiPath,
        int? Count,
        bool CountIsApproximate = false);
}
