@page "/reset-password"
@using Microsoft.AspNetCore.WebUtilities
@using Lidstroem.Frontend.Core.Services
@layout AuthLayout
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Set your password</PageTitle>

<div class="auth-card">

    @if (_tokenMissing)
    {
        <div class="auth-error-state">
            <Icon Name="alert-circle" Size="40" />
            <h2>Invalid link</h2>
            <p>This password reset link is missing or malformed.</p>
            <a href="/login" class="btn btn-primary" style="margin-top:1rem;">Go to login</a>
        </div>
    }
    else if (_done)
    {
        <div class="auth-success-state">
            <Icon Name="check-circle" Size="40" />
            <h2>Password set</h2>
            <p>Your password has been saved. Redirecting to sign in…</p>
            <a href="/login" class="btn btn-primary" style="margin-top:1rem;">Sign in now</a>
        </div>
    }
    else
    {
        <h1 class="auth-title">Set your password</h1>
        <p class="auth-subtitle">Choose a password to activate your account.</p>

        <div class="auth-form">
            <div class="form-field required">
                <label class="field-label">New password</label>
                <input class="field-input @(_error != null ? "field-input--error" : "")"
                       type="password"
                       @bind="_password"
                       placeholder="Min. 8 characters"
                       @onkeydown="OnKeyDown" />
            </div>
            <div class="form-field required">
                <label class="field-label">Confirm password</label>
                <input class="field-input @(_error != null ? "field-input--error" : "")"
                       type="password"
                       @bind="_confirm"
                       placeholder="Repeat password"
                       @onkeydown="OnKeyDown" />
            </div>

            @if (_error != null)
            {
                <div class="form-error">@_error</div>
            }

            <button class="btn btn-primary btn--full"
                    @onclick="Submit"
                    disabled="@(_busy
                                || string.IsNullOrWhiteSpace(_password)
                                || string.IsNullOrWhiteSpace(_confirm))">
                @if (_busy) { <span class="btn-spinner"></span> }
                @(_busy ? "Saving…" : "Set password and sign in")
            </button>
        </div>
    }

</div>

@code {
    private string  _token    = string.Empty;
    private string  _password = string.Empty;
    private string  _confirm  = string.Empty;
    private string? _error;
    private bool    _busy;
    private bool    _done;
    private bool    _tokenMissing;

    protected override void OnInitialized()
    {
        // FIX: System.Web.HttpUtility is not available in Blazor WASM.
        // Use Microsoft.AspNetCore.WebUtilities.QueryHelpers instead.
        var query = QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
        _token = query.TryGetValue("token", out var t) ? t.ToString() : string.Empty;
        if (string.IsNullOrWhiteSpace(_token)) _tokenMissing = true;
    }

    private async Task Submit()
    {
        _error = null;
        if (_password.Length < 8)         { _error = "Password must be at least 8 characters."; return; }
        if (_password != _confirm)         { _error = "Passwords do not match."; return; }

        _busy = true;
        var ok = await Api.PostAsync("/api/auth/reset-password",
            new { Token = _token, Password = _password });
        _busy = false;

        if (ok == null)
        {
            _error = "The link is invalid or has expired. Ask your administrator for a new one.";
            return;
        }
        _done = true;

        // BUG-15 FIX: No auto-redirect after success — user was left on the page
        // with a manual link. If they closed the tab the token was consumed but
        // they'd never reached login. Auto-redirect after 3 seconds.
        _ = Task.Delay(3000).ContinueWith(_ =>
            InvokeAsync(() => Nav.NavigateTo("/login")));
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }
}
