@page "/admin/tenants"
@using System.Text.Json
@using Lidstroem.Frontend.Core.Services
@inject ApiClient Api
@inject PermissionService Permissions
@inject NavigationManager Nav

<PageTitle>Organisations</PageTitle>

@if (!Permissions.Has("SuperAdmin.ManageTenants"))
{
    <div class="list-empty"><p>You do not have permission to manage organisations.</p></div>
    return;
}

<div class="page-header">
    <h1 class="page-title">Organisations</h1>
    <div class="page-header-actions">
        <button class="btn btn-primary" @onclick="OpenCreate">
            <Icon Name="plus" Size="14" /> New organisation
        </button>
    </div>
</div>

@if (_loading)
{
    <div class="skeleton-page">
        @for (var i = 0; i < 4; i++) { <div class="skeleton-row" style="margin-bottom:.5rem;"></div> }
    </div>
}
else if (_tenants.Count == 0)
{
    <div class="list-empty">
        <Icon Name="building-2" Size="40" />
        <p>No organisations yet.</p>
        <button class="btn btn-primary" @onclick="OpenCreate">Create the first organisation</button>
    </div>
}
else
{
    @* BUG-23 FIX: was using entity-table / empty-state / cell-primary / cell-actions
       which are not defined in app.css. Replaced with design-system classes:
       data-table-wrapper, data-table, list-empty, actions-cell. *@
    <div class="data-table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact email</th>
                    <th>Active plugins</th>
                    <th>Status</th>
                    <th class="actions-col"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in _tenants)
                {
                    var tid = TenantId(t);
                    <tr class="data-row" @onclick="() => OpenDetail(tid)">
                        <td><strong>@Name(t)</strong></td>
                        <td>@(ContactEmail(t) ?? "—")</td>
                        <td>@PluginCount(t)</td>
                        <td>
                            @if (IsActive(t))
                            {
                                <span class="badge badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-neutral">Inactive</span>
                            }
                        </td>
                        <td class="actions-cell" @onclick:stopPropagation>
                            <div class="row-actions">
                                <button class="btn btn-ghost btn-sm"
                                        @onclick="() => OpenDetail(tid)">
                                    Edit
                                </button>
                                @if (IsActive(t))
                                {
                                    <button class="btn btn-ghost btn-sm"
                                            @onclick="() => ToggleActive(t, false)"
                                            disabled="@_busy">
                                        Deactivate
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-ghost btn-sm"
                                            @onclick="() => ToggleActive(t, true)"
                                            disabled="@_busy">
                                        Activate
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_error != null)
{
    <div class="form-error" style="margin-top:1rem;">@_error</div>
}

@* ── Create modal ──────────────────────────────────────────────────────────── *@
@if (_showCreate)
{
    <div class="modal-backdrop" @onclick="CloseCreate">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="modal-title">New organisation</h2>
                <button class="modal-close" @onclick="CloseCreate">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-field required">
                    <label class="field-label">Name</label>
                    <input class="field-input" @bind="_newName" placeholder="Organisation name" />
                </div>
                <div class="form-field">
                    <label class="field-label">Contact email</label>
                    <input class="field-input" type="email" @bind="_newEmail"
                           placeholder="contact@example.com" />
                </div>
                <div class="form-field">
                    <label class="field-label">Description</label>
                    <textarea class="field-input" @bind="_newDescription"
                              rows="3" placeholder="Optional"></textarea>
                </div>
                <div class="form-field">
                    <label class="field-label">Actor quota</label>
                    @* BUG-32 FIX: int? @bind on number input throws parse exception in
                       Blazor WASM when field is left empty. Bind to string and parse manually. *@
                    <input class="field-input" type="number"
                           value="@_newActorQuotaRaw"
                           @oninput="e => _newActorQuotaRaw = e.Value?.ToString() ?? string.Empty"
                           placeholder="Unlimited" min="1" max="100000" />
                </div>
                @if (_createError != null)
                {
                    <div class="form-error">@_createError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseCreate">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateTenant"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_newName))">
                    @(_busy ? "Creating…" : "Create organisation")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<JsonElement> _tenants = new();
    private bool _loading = true;
    private bool _busy;
    private string? _error;

    private bool    _showCreate;
    private string  _newName        = string.Empty;
    private string  _newEmail       = string.Empty;
    private string  _newDescription = string.Empty;
    // BUG-32 FIX: int? bind on number-input throws in Blazor WASM when empty.
    private string  _newActorQuotaRaw = string.Empty;
    private string? _createError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        var result = await Api.GetListAsync("/api/admin/tenants");
        if (result == null) _error = "Failed to load organisations.";
        _tenants = result ?? new();
        _loading = false;
    }

    private void OpenCreate()
    {
        _newName = _newEmail = _newDescription = _newActorQuotaRaw = string.Empty;
        _createError = null;
        _showCreate  = true;
    }

    private void CloseCreate() => _showCreate = false;

    private async Task CreateTenant()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;
        _busy = true; _createError = null;

        var result = await Api.PostAsync("/api/admin/tenants", new
        {
            Name         = _newName.Trim(),
            ContactEmail = string.IsNullOrWhiteSpace(_newEmail) ? null : _newEmail.Trim(),
            Description  = string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription.Trim(),
            ActorQuota   = int.TryParse(_newActorQuotaRaw, out var q) ? q : (int?)null
        });

        _busy = false;

        if (result == null)
        {
            _createError = "Failed to create. Check that the name is unique.";
            return;
        }

        _showCreate = false;
        await LoadAsync();
    }

    private async Task ToggleActive(JsonElement t, bool activate)
    {
        _busy = true;
        var id  = TenantId(t);
        var url = activate
            ? "/api/admin/tenants/" + id + "/activate"
            : "/api/admin/tenants/" + id + "/deactivate";
        await Api.PutAsync(url, new { });
        _busy = false;
        await LoadAsync();
    }

    private void OpenDetail(int id) => Nav.NavigateTo("/admin/tenants/" + id);

    private static int     TenantId(JsonElement t)     => t.TryGetProperty("id",           out var p) ? p.GetInt32()    : 0;
    private static string  Name(JsonElement t)          => t.TryGetProperty("name",         out var p) ? p.GetString() ?? "—" : "—";
    private static string? ContactEmail(JsonElement t)  => t.TryGetProperty("contactEmail", out var p) ? p.GetString()  : null;
    private static bool    IsActive(JsonElement t)      => t.TryGetProperty("isActive",     out var p) && p.GetBoolean();
    private static int PluginCount(JsonElement t)
    {
        if (!t.TryGetProperty("pluginAssignments", out var arr)) return 0;
        return arr.EnumerateArray().Count(a =>
            a.TryGetProperty("isEnabled", out var e) && e.GetBoolean());
    }
}
